        </mxCell>

        <!-- ==================== -->
        <!-- LEGEND -->
        <!-- ==================== -->
        <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;━━ 12V DC Power&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;━━ 5V DC Power&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#0000cc&quot;&gt;━━ USB Connection&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#006699&quot;&gt;━━ Ethernet / PoE&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#00aa00&quot;&gt;━━ GPIO Signal&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#aa00aa&quot;&gt;━━ I2C Bus&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#cc6600&quot;&gt;- - 1-Wire Bus&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#ff8800&quot;&gt;- - RF / Antenna&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=1.5;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="70" width="280" height="160" as="geometry"/>
        </mxCell>

        <!-- ==================== -->
        <!-- POWER BUDGET -->
        <!-- ==================== -->
        <mxCell id="budget" value="&lt;b&gt;POWER BUDGET&lt;/b&gt;&lt;br&gt;&lt;br&gt;Raspberry Pi 5: 15W&lt;br&gt;Quectel modem: 5W&lt;br&gt;PoE camera: 12W&lt;br&gt;LEDs/sensors/misc: 2W&lt;br&gt;&lt;b&gt;Active: ~34W&lt;/b&gt;&lt;br&gt;Sleep: ~1.5W (Pi halt state)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Daily: ~94 Wh | Autonomy: ~3.2 days&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#333333;strokeWidth=1.5;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="460" width="280" height="180" as="geometry"/>
        </mxCell>

        <!-- ==================== -->
        <!-- ASSEMBLY NOTES -->
        <!-- ==================== -->
        <mxCell id="notes" value="&lt;b&gt;ASSEMBLY NOTES&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. Stack Order: Pi 5 (bottom) + Pi-EzConnect (top) - all on DIN rail clip&lt;br&gt;2. Apply MG 422C silicone conformal coat to: Pi 5, Pi-EzConnect. Mask connectors/headers&lt;br&gt;3. DDR-60G-5: Regulated 5V for compute. DDR-60G-12: Regulated 12V for PoE switch (battery varies 10-14V)&lt;br&gt;4. Relay-POE: GPIO-triggered 4-CH SPDT. IN1 (GPIO 24) = PoE switch. IN2/3/4 (GPIO 17/27/22) = LEDs&lt;br&gt;5. Proxicast puck antenna: 12mm hole in enclosure top, rubber gasket seal. Internal SMA pigtails to modem U.FL&lt;br&gt;6. SHT40 (inside enclosure) monitors climate. DS18B20 probe (outside, PG9 gland) for ambient temp/dew point&lt;br&gt;7. Pi 5 built-in RTC (ML-2020 coin cell) provides scheduling via Rainbow Sensing image&lt;br&gt;8. Gore M12 vent for pressure equalization. No heaters (solar power budget). Carrier: Telkomsel&lt;br&gt;9. External power button wired to Pi 5 J2 header (not GPIO). Press to power on/off; hold 5s to force-off" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#333333;strokeWidth=1.5;align=left;spacingLeft=10;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="670" width="1130" height="200" as="geometry"/>
        </mxCell>

        <!-- ==================== -->
        <!-- GPIO PIN TABLE -->
        <!-- ==================== -->
        <mxCell id="gpio-table" value="&lt;b&gt;GPIO PIN ASSIGNMENTS&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot;&gt;GPIO  2   SDA         I2C       SHT40 sensor (0x44)&lt;br&gt;GPIO  3   SCL         I2C       SHT40 sensor&lt;br&gt;GPIO 14   UART TX     Serial    To Hydreon RG-15 RX&lt;br&gt;GPIO 15   UART RX     Serial    From Hydreon RG-15 TX&lt;br&gt;GPIO  4   DS18B20     1-Wire    Outside temp (4.7k pull-up)&lt;br&gt;GPIO 17   Relay IN2   Output    LED Green / System OK&lt;br&gt;GPIO 22   Relay IN4   Output    LED Red / Error&lt;br&gt;GPIO 23   Button      Input     Maintenance mode (3s hold)&lt;br&gt;GPIO 24   Relay IN1   Output    PoE switch&lt;br&gt;GPIO 27   Relay IN3   Output    LED Yellow / Working/uploading&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=1.5;align=left;spacingLeft=10;fontSize=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="880" width="570" height="200" as="geometry"/>
        </mxCell>

        <!-- ==================== -->
        <!-- FUSE SCHEDULE -->
        <!-- ==================== -->
