        <mxCell id="vtable-text" value="&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;table style=&quot;border-collapse: collapse;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;&lt;b&gt;Component&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;&lt;b&gt;Voltage&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;&lt;b&gt;Protection&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;Solar system&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;12V nom&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;&amp;mdash;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;Witty Pi in&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;12V (5-26V)&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;Internal OCP&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;Pi 5 (USB-C)&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;5V&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;From Witty Pi&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;PoE injector&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;12V&amp;rarr;48V&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;5A inline fuse&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;Camera (PoE)&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;48V&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;802.3af/at&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;LTE modem&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;5V USB&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;Pi USB OCP&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;GPIO signals&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;3.3V&lt;/td&gt;&lt;td style=&quot;padding: 2px 8px;&quot;&gt;330&amp;Omega; series R&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&