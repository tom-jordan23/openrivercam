[Unit]
Description=LED status indicator (WS2812B on GPIO 18)
After=local-fs.target

[Service]
Type=simple
ExecStart=/usr/local/bin/orc-led-status
ExecStopPost=/usr/local/bin/orc-led-status --off
Restart=on-failure
RestartSec=5

# WS2812B requires root for RP1 PIO access (/dev/pio0)
User=root

# Hardening — limit root's scope
ProtectHome=read-only
ProtectSystem=strict
ReadWritePaths=/sys /dev
NoNewPrivileges=yes
PrivateTmp=yes
RuntimeDirectory=orc-led-status
WorkingDirectory=/run/orc-led-status

Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="ORC_LED_STATUS_CONF=/etc/orc/led-status.yaml"

[Install]
WantedBy=multi-user.target
