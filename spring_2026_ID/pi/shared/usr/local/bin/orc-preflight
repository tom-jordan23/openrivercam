#!/bin/bash
# orc-preflight — pre-deployment checks for ORC Pi stations
#
# Verifies that required packages, configurations, and services are
# present and correctly set up. Run this before deploying to the field.
#
# Usage: orc-preflight [--fix]
#   --fix   Attempt to fix issues automatically (requires sudo)

set -o pipefail

FIX=0
if [ "$1" = "--fix" ]; then
    FIX=1
fi

PASS=0
FAIL=0
WARN=0

pass() {
    echo "  [PASS] $1"
    PASS=$((PASS + 1))
}

fail() {
    echo "  [FAIL] $1"
    FAIL=$((FAIL + 1))
}

warn() {
    echo "  [WARN] $1"
    WARN=$((WARN + 1))
}

# ─── System Packages ─────────────────────────────────────────────────

echo ""
echo "=== Required Packages ==="

REQUIRED_PKGS="dnsmasq modemmanager gpiod chrony minicom"
OPTIONAL_PKGS=""
MISSING_REQ=""

for pkg in $REQUIRED_PKGS; do
    if dpkg -s "$pkg" >/dev/null 2>&1; then
        pass "$pkg installed"
    else
        fail "$pkg not installed"
        MISSING_REQ="$MISSING_REQ $pkg"
    fi
done

for pkg in $OPTIONAL_PKGS; do
    if [ -n "$pkg" ] && dpkg -s "$pkg" >/dev/null 2>&1; then
        pass "$pkg installed (optional)"
    elif [ -n "$pkg" ]; then
        warn "$pkg not installed (optional — debugging only)"
    fi
done

if [ -n "$MISSING_REQ" ] && [ "$FIX" -eq 1 ]; then
    echo "  ... installing missing packages:$MISSING_REQ"
    sudo apt-get update -qq && sudo apt-get install -y -qq $MISSING_REQ
fi

# ─── Python Packages ─────────────────────────────────────────────────

echo ""
echo "=== Python Packages ==="

REQUIRED_PY="requests smbus2 neopixel yaml"
OPTIONAL_PY="pyserial"

for pkg in $REQUIRED_PY; do
    if python3 -c "import $pkg" 2>/dev/null; then
        pass "python3-$pkg available"
    else
        fail "python3-$pkg not available"
    fi
done

for pkg in $OPTIONAL_PY; do
    if python3 -c "import serial" 2>/dev/null; then
        pass "python3-$pkg available (optional)"
    else
        warn "python3-$pkg not available (optional — debugging only)"
    fi
done

# ─── User/Group ───────────────────────────────────────────────────────

echo ""
echo "=== User/Group ==="

if id -nG | grep -qw dialout; then
    pass "$USER is in dialout group"
else
    fail "$USER is NOT in dialout group (needed for serial/modem access)"
    if [ "$FIX" -eq 1 ]; then
        echo "  ... adding $USER to dialout group"
        sudo usermod -aG dialout "$USER"
        echo "  ... NOTE: log out and back in for group change to take effect"
    fi
fi

# ─── USB Storage ─────────────────────────────────────────────────────

echo ""
echo "=== USB Storage ==="

# USB drive mounted at /mnt/usb
if mountpoint -q /mnt/usb 2>/dev/null; then
    USB_FS=$(findmnt -n -o FSTYPE /mnt/usb 2>/dev/null)
    USB_SIZE=$(df -h /mnt/usb 2>/dev/null | awk 'NR==2{print $2}')
    if [ "$USB_FS" = "ext4" ]; then
        pass "/mnt/usb mounted (ext4, $USB_SIZE)"
    else
        warn "/mnt/usb mounted but filesystem is $USB_FS (expected ext4)"
    fi
else
    fail "/mnt/usb not mounted"
    if grep -q "/mnt/usb" /etc/fstab 2>/dev/null; then
        warn "  fstab entry exists — drive may be disconnected"
        if [ "$FIX" -eq 1 ]; then
            echo "  ... attempting mount"
            sudo mount /mnt/usb 2>/dev/null && pass "  mounted successfully" || fail "  mount failed"
        fi
    else
        fail "  no fstab entry for /mnt/usb"
    fi
fi

# ~/Videos directory (captures stored on SD card)
if [ -d /home/pi/Videos ]; then
    pass "~/Videos directory exists"
else
    warn "~/Videos does not exist"
    if [ "$FIX" -eq 1 ]; then
        echo "  ... creating ~/Videos"
        mkdir -p /home/pi/Videos && pass "  fixed"
    fi
fi

# ─── Overlay Files ────────────────────────────────────────────────────

echo ""
echo "=== Configuration Files ==="

# dnsmasq config
if [ -f /etc/dnsmasq.d/maintenance.conf ]; then
    if grep -q "^bind-dynamic" /etc/dnsmasq.d/maintenance.conf; then
        pass "/etc/dnsmasq.d/maintenance.conf present with bind-dynamic"
    elif grep -q "^bind-interfaces" /etc/dnsmasq.d/maintenance.conf; then
        fail "/etc/dnsmasq.d/maintenance.conf uses bind-interfaces (should be bind-dynamic)"
        if [ "$FIX" -eq 1 ]; then
            echo "  ... fixing: bind-interfaces → bind-dynamic"
            sudo sed -i 's/^bind-interfaces$/bind-dynamic/' /etc/dnsmasq.d/maintenance.conf
        fi
    else
        warn "/etc/dnsmasq.d/maintenance.conf present but missing bind directive"
    fi
else
    fail "/etc/dnsmasq.d/maintenance.conf not found"
fi

# NetworkManager camera-net connection
if nmcli -t -f NAME con show 2>/dev/null | grep -q "camera-net"; then
    CAM_IP=$(nmcli -t -f ipv4.addresses con show camera-net 2>/dev/null)
    if echo "$CAM_IP" | grep -q "192.168.50.1/24"; then
        pass "camera-net connection exists (192.168.50.1/24)"
    else
        fail "camera-net connection exists but IP is wrong: $CAM_IP"
    fi
else
    fail "camera-net NetworkManager connection not found"
fi

# poe-relay script (check PATH, could be in ~/.local/bin or /usr/local/bin)
if command -v poe-relay >/dev/null 2>&1; then
    POE_PATH=$(command -v poe-relay)
    pass "poe-relay found at $POE_PATH"
else
    fail "poe-relay not found in PATH"
fi

# camtool.py — camera ISAPI configuration management
if command -v camtool.py >/dev/null 2>&1; then
    pass "camtool.py found at $(command -v camtool.py)"
else
    fail "camtool.py not found in PATH"
fi

# camera_profiles directory
if [ -d /home/pi/camera_profiles ]; then
    PROFILE_COUNT=$(find /home/pi/camera_profiles -name "*.xml" 2>/dev/null | wc -l)
    if [ "$PROFILE_COUNT" -gt 0 ]; then
        pass "~/camera_profiles/ exists ($PROFILE_COUNT XML profiles)"
    else
        warn "~/camera_profiles/ exists but has no XML profiles (run: camtool.py pull <camera>)"
    fi
else
    fail "~/camera_profiles/ not found"
    if [ "$FIX" -eq 1 ]; then
        echo "  ... creating ~/camera_profiles/"
        mkdir -p /home/pi/camera_profiles && pass "  fixed"
    fi
fi

# QEMU udev rules — required for boot on Rainbow Sensing images.
# These rules symlink sda → mmcblk0 so the OS finds its root partition.
# Removing this file causes a boot partition enumeration failure that drops
# the system into emergency mode. See BOOT_FAILURE_ANALYSIS.md.
QEMU_RULES="/etc/udev/rules.d/90-qemu.rules"
if [ -f "$QEMU_RULES" ]; then
    if grep -q 'KERNEL=="sda", SYMLINK+="mmcblk0"' "$QEMU_RULES"; then
        pass "90-qemu.rules present (required for boot — do NOT remove)"
    else
        warn "90-qemu.rules exists but has unexpected contents"
    fi
else
    fail "90-qemu.rules MISSING — system may not survive a reboot!"
    echo "         Restore from BOOT_FAILURE_ANALYSIS.md immediately."
fi

# Boot firmware partition — not mounted when 90-qemu.rules is active.
# The udev rules remap sda → mmcblk0, so the PARTUUID lookup for the boot
# partition finds the USB drive instead of the real SD card boot partition.
# This is expected and harmless — config.txt changes require manual mount.
if mountpoint -q /boot/firmware 2>/dev/null; then
    pass "/boot/firmware mounted"
else
    if [ -f "$QEMU_RULES" ]; then
        warn "/boot/firmware not mounted (expected — 90-qemu.rules remaps mmcblk0)"
        echo "         To edit config.txt: sudo mount /dev/mmcblk0p1 /boot/firmware (find real device first)"
    else
        fail "/boot/firmware not mounted (config.txt inaccessible)"
    fi
fi

# Witty Pi 5 HAT+ (RTC + power management — replaces Pi 5 native ML-2020 RTC battery)
if i2cdetect -y 1 2>/dev/null | grep -q "51"; then
    pass "Witty Pi 5 HAT+ detected on I2C bus (0x51)"
else
    fail "Witty Pi 5 HAT+ NOT detected on I2C bus (expected at 0x51)"
    echo "         Check that Witty Pi 5 is seated on GPIO header and CR2032 battery is installed."
fi
if command -v wp5 >/dev/null 2>&1; then
    pass "Witty Pi 5 software installed (wp5)"
    if systemctl is-active --quiet wp5d 2>/dev/null; then
        pass "Witty Pi 5 daemon running (wp5d)"
    else
        warn "Witty Pi 5 daemon not running (wp5d) — start with: sudo systemctl start wp5d"
    fi
else
    fail "Witty Pi 5 software not installed — install wp5_latest.deb from UUGear"
fi

# (legacy check removed: ML-2020 RTC battery connector failed on both boards)
CONFIG_TXT="/boot/firmware/config.txt"
if [ -f "$CONFIG_TXT" ]; then
    :  # config.txt accessible, no ML-2020 checks needed
else
    if [ -f "$QEMU_RULES" ]; then
        warn "$CONFIG_TXT not accessible (/boot/firmware not mounted — see above)"
    else
        fail "$CONFIG_TXT not found"
    fi
fi

# hosts file camera entry — check for any camera hostname in the 192.168.50.x range
if grep -q "192\.168\.50\.[0-9].*camera\|camera.*192\.168\.50\.[0-9]" /etc/hosts 2>/dev/null; then
    CAM_HOST_LINE=$(grep "192\.168\.50\.[0-9].*camera" /etc/hosts 2>/dev/null | head -1)
    pass "/etc/hosts has camera entry ($CAM_HOST_LINE)"
else
    warn "/etc/hosts missing camera hostname entry"
fi

# orc-sensors config directory
if [ -d /etc/orc-sensors ] && ls /etc/orc-sensors/*.conf >/dev/null 2>&1; then
    SENSOR_COUNT=$(ls /etc/orc-sensors/*.conf 2>/dev/null | wc -l)
    pass "/etc/orc-sensors/ has $SENSOR_COUNT sensor config(s)"
else
    warn "/etc/orc-sensors/ not found or empty (sensor logging will not run)"
fi

# orc-sensors log directory
ORC_SENSORS_LOG_DIR="/var/log/orc/sensors"
if [ -d /etc/orc-sensors ]; then
    # Check the LOG_DIR from the first config file found
    FIRST_CONF=$(ls /etc/orc-sensors/*.conf 2>/dev/null | head -1)
    if [ -n "$FIRST_CONF" ]; then
        CONF_LOG_DIR=$(grep "^LOG_DIR=" "$FIRST_CONF" 2>/dev/null | cut -d= -f2 | xargs)
        ORC_SENSORS_LOG_DIR="${CONF_LOG_DIR:-$ORC_SENSORS_LOG_DIR}"
    fi
fi
if [ -d "$ORC_SENSORS_LOG_DIR" ] && [ -w "$ORC_SENSORS_LOG_DIR" ]; then
    pass "sensor log directory writable ($ORC_SENSORS_LOG_DIR)"
elif [ -d "$ORC_SENSORS_LOG_DIR" ]; then
    fail "sensor log directory exists but not writable ($ORC_SENSORS_LOG_DIR)"
else
    warn "sensor log directory does not exist yet ($ORC_SENSORS_LOG_DIR) — created on first run"
fi

# ─── Services ─────────────────────────────────────────────────────────

echo ""
echo "=== Services ==="

# orc-capture service (our relay + capture workflow)
if systemctl is-enabled orc-capture >/dev/null 2>&1; then
    pass "orc-capture service enabled"
else
    warn "orc-capture service not enabled (run: sudo systemctl enable orc-capture)"
fi

# orc-sensors timer (environmental sensor logging)
if systemctl is-enabled orc-sensors.timer >/dev/null 2>&1; then
    pass "orc-sensors.timer enabled"
else
    warn "orc-sensors.timer not enabled (run: sudo systemctl enable orc-sensors.timer)"
fi

# orc-led-status service (WS2812B status LED)
if systemctl is-enabled orc-led-status >/dev/null 2>&1; then
    if systemctl is-active orc-led-status >/dev/null 2>&1; then
        pass "orc-led-status enabled and running"
    else
        fail "orc-led-status enabled but NOT running"
    fi
else
    warn "orc-led-status not enabled (run: sudo systemctl enable orc-led-status)"
fi

# LED status config
if [ -f /etc/orc/led-status.yaml ]; then
    pass "/etc/orc/led-status.yaml present"
else
    fail "/etc/orc/led-status.yaml not found"
fi

# orc-gpio-relays must be DISABLED — it uses active-low logic incompatible
# with our Electronics-Salon relay module (active-high). orc-capture handles
# relay control directly via poe-relay.
if systemctl is-enabled orc-gpio-relays >/dev/null 2>&1; then
    fail "orc-gpio-relays is ENABLED — conflicts with orc-capture (active-low vs active-high)"
    echo "         Disable with: sudo systemctl disable orc-gpio-relays"
    if [ "$FIX" -eq 1 ]; then
        echo "  ... disabling orc-gpio-relays"
        sudo systemctl disable orc-gpio-relays 2>/dev/null
        sudo systemctl stop orc-gpio-relays 2>/dev/null
    fi
else
    pass "orc-gpio-relays disabled (correct — orc-capture owns relay)"
fi

for svc in dnsmasq NetworkManager ModemManager chrony; do
    if systemctl is-enabled "$svc" >/dev/null 2>&1; then
        if systemctl is-active "$svc" >/dev/null 2>&1; then
            pass "$svc enabled and running"
        else
            fail "$svc enabled but NOT running"
            if [ "$FIX" -eq 1 ]; then
                echo "  ... restarting $svc"
                sudo systemctl restart "$svc"
            fi
        fi
    else
        fail "$svc not enabled"
        if [ "$FIX" -eq 1 ]; then
            echo "  ... enabling and starting $svc"
            sudo systemctl enable --now "$svc"
        fi
    fi
done

# ─── Hardware ─────────────────────────────────────────────────────────

echo ""
echo "=== Hardware ==="

# Pi model
PI_MODEL=$(tr -d '\0' < /proc/device-tree/model 2>/dev/null)
if echo "$PI_MODEL" | grep -q "Pi 5"; then
    pass "Raspberry Pi 5 detected ($PI_MODEL)"
else
    warn "Expected Pi 5, found: $PI_MODEL"
fi

# USB flash drive (SanDisk Ultra Fit or Samsung FIT Plus)
if lsblk -o NAME,MODEL 2>/dev/null | grep -qi "FIT.*Plus\|Samsung.*FIT\|SanDisk.*3.2"; then
    USB_MODEL=$(lsblk -o MODEL -n /dev/sda 2>/dev/null | xargs)
    pass "USB flash drive detected (${USB_MODEL:-unknown})"
elif [ -b /dev/sda ]; then
    USB_MODEL=$(lsblk -o MODEL -n /dev/sda 2>/dev/null | xargs)
    warn "USB block device found but unrecognized model: ${USB_MODEL:-unknown}"
else
    warn "No USB storage device detected"
fi

# LTE modem
if mmcli -L 2>/dev/null | grep -qi "quectel\|EG25"; then
    pass "LTE modem detected (Quectel EG25-G)"
elif lsusb 2>/dev/null | grep -qi "quectel\|2c7c"; then
    warn "Quectel USB device found but ModemManager doesn't see it"
else
    fail "LTE modem not detected"
fi

# I2C (SHT40 sensor)
if [ -e /dev/i2c-1 ]; then
    pass "I2C bus available (/dev/i2c-1)"
    if command -v i2cdetect >/dev/null 2>&1; then
        if i2cdetect -y 1 2>/dev/null | grep -q "44"; then
            pass "SHT40 sensor detected on I2C bus (0x44)"
        else
            warn "I2C bus available but SHT40 (0x44) not detected"
        fi
    fi
else
    fail "I2C bus not available (/dev/i2c-1 missing — enable with raspi-config)"
fi

# Witty Pi 5 RTC time sanity check
if command -v wp5 >/dev/null 2>&1; then
    WP5_RTC=$(echo "14" | wp5 2>/dev/null | grep "RTC Time:" | head -1 | sed 's/.*RTC Time: //')
    SYS_EPOCH=$(date -u +%s)
    if [ -n "$WP5_RTC" ]; then
        RTC_EPOCH=$(date -u -d "$WP5_RTC" +%s 2>/dev/null)
        if [ -n "$RTC_EPOCH" ]; then
            DRIFT=$(( SYS_EPOCH - RTC_EPOCH ))
            DRIFT=${DRIFT#-}  # absolute value
            if [ "$DRIFT" -le 5 ]; then
                pass "Witty Pi 5 RTC in sync with system clock (${WP5_RTC})"
            else
                warn "Witty Pi 5 RTC drift: ${DRIFT}s (RTC: ${WP5_RTC}) — sync with: wp5 option 1"
            fi
        fi
    fi
fi

# USB max current (required when powering Pi via 5V GPIO rail — no USB-C PD negotiation)
if grep -q "^usb_max_current_enable=1" /boot/firmware/config.txt 2>/dev/null; then
    pass "USB max current enabled (usb_max_current_enable=1)"
else
    fail "usb_max_current_enable=1 missing from config.txt (modem will trigger USB over-current)"
fi

# 1-Wire (DS18B20 sensor)
if ls /sys/bus/w1/devices/28-* >/dev/null 2>&1; then
    pass "DS18B20 temperature probe detected on 1-Wire bus"
else
    warn "DS18B20 not detected on 1-Wire bus (check GPIO 4 + 4.7k pull-up)"
fi

# ─── Network ──────────────────────────────────────────────────────────

echo ""
echo "=== Network ==="

# eth0
ETH0_IP=$(ip -4 -o addr show eth0 2>/dev/null | awk '{print $4}')
if [ -n "$ETH0_IP" ]; then
    if echo "$ETH0_IP" | grep -q "192.168.50.1/24"; then
        pass "eth0: $ETH0_IP"
    else
        warn "eth0 has IP $ETH0_IP (expected 192.168.50.1/24)"
    fi
else
    warn "eth0: no IP address (PoE relay may be off — this is normal if relay is off)"
fi

# PoE relay state — if pin is unconfigured after reboot, read as input
POE_STATE=$(pinctrl get 24 2>/dev/null)
if echo "$POE_STATE" | grep -q "| --"; then
    pinctrl set 24 ip 2>/dev/null
    POE_STATE=$(pinctrl get 24 2>/dev/null)
fi
if echo "$POE_STATE" | grep -q "| hi"; then
    pass "PoE relay: ON (GPIO 24 HIGH — relay energized)"
elif echo "$POE_STATE" | grep -q "| lo"; then
    warn "PoE relay: OFF (GPIO 24 LOW — relay de-energized) — camera/eth0 unpowered"
else
    warn "PoE relay: unknown state (GPIO 24 not readable)"
fi

# Camera reachability (only if eth0 is up)
# Uses DHCP leases (actual devices on the network) rather than dhcp-host
# reservations, which may not match if the camera MAC hasn't been configured.
LEASE_FILE="/var/lib/misc/dnsmasq.leases"
if [ -n "$ETH0_IP" ]; then
    FOUND_CAMERA=0
    if [ -f "$LEASE_FILE" ]; then
        while read -r _ts mac cam_ip hostname _id; do
            [ "$cam_ip" = "192.168.50.1" ] && continue
            if ping -c 1 -W 2 "$cam_ip" >/dev/null 2>&1; then
                pass "Camera at $cam_ip ($mac): reachable"
            else
                warn "Camera at $cam_ip ($mac): lease active, not responding"
            fi
            FOUND_CAMERA=1
        done < "$LEASE_FILE"
    fi
    if [ "$FOUND_CAMERA" -eq 0 ]; then
        warn "No DHCP leases — no cameras detected on eth0"
    fi

    # Camera supplement light check (only if camera is reachable)
    # The ANNKE C1200 reverts supplementLightMode to eventIntelligence on
    # power cycle, which causes bright white LED flashes at night.
    CAM_PASS=""
    for f in ~/.orc_deploy_*; do
        if [ -f "$f" ]; then
            # shellcheck disable=SC1090
            CAM_PASS=$(grep "^BASE_PASSWD=" "$f" 2>/dev/null | cut -d= -f2)
            break
        fi
    done
    if [ -n "$CAM_PASS" ] && [ -f "$LEASE_FILE" ]; then
        while read -r _ts _mac cam_ip _hostname _id; do
            [ "$cam_ip" = "192.168.50.1" ] && continue
            if ping -c 1 -W 1 "$cam_ip" >/dev/null 2>&1; then
                LIGHT_MODE=$(curl -s --digest -u "admin:${CAM_PASS}" \
                    "http://${cam_ip}/ISAPI/Image/channels/1" 2>/dev/null \
                    | grep -o '<supplementLightMode>[^<]*</supplementLightMode>' \
                    | sed 's/<[^>]*>//g')
                if [ "$LIGHT_MODE" = "irLight" ]; then
                    pass "Camera $cam_ip: supplement light = irLight"
                elif [ -n "$LIGHT_MODE" ]; then
                    fail "Camera $cam_ip: supplement light = $LIGHT_MODE (should be irLight)"
                    echo "         White LEDs may flash at night. orc-capture fixes this on each cycle."
                    if [ "$FIX" -eq 1 ]; then
                        echo "  ... run: orc-capture --skip-relay --dry-run (to enforce irLight)"
                    fi
                fi
            fi
        done < "$LEASE_FILE"
    fi
fi

# ─── Summary ──────────────────────────────────────────────────────────

echo ""
echo "==============================="
echo "  PASS: $PASS   FAIL: $FAIL   WARN: $WARN"
echo "==============================="

if [ "$FAIL" -gt 0 ]; then
    echo ""
    echo "There are failures that should be fixed before deployment."
    if [ "$FIX" -eq 0 ]; then
        echo "Run with --fix to attempt automatic fixes."
    fi
    exit 1
elif [ "$WARN" -gt 0 ]; then
    echo ""
    echo "Warnings are informational — review but may not need action."
    exit 0
else
    echo ""
    echo "All checks passed. Ready for deployment."
    exit 0
fi
