#!/bin/bash
# orc-sensors-upload — push new sensor CSVs to the LiveORC server via HTTPS PUT
#
# SEPARATION OF CONCERNS NOTE: This script is invoked from orc-capture as a
# step in the wake-cycle, not because sensor upload belongs in capture but
# because we need wake-cycle sequencing to avoid being killed by ORC-OS's
# shutdown trigger. The long-term plan is to extract capture, sensor upload,
# and shutdown decision into an orc-cycle orchestrator. Don't expand this
# script's responsibilities; if you need additional pre-upload work, add a
# separate step in orc-capture rather than bundling here.
#
# Reads /etc/orc/sensors-upload.conf for UPLOAD_URL / LOG_DIR / STATE_FILE.
# Reads ~pi/.orc_deploy_<site> for UPLOAD_TOKEN (out-of-band secret).
# Files under LOG_DIR newer than STATE_FILE's mtime are PUT to:
#   <UPLOAD_URL>/<station>/<filename>
# with an `Authorization: Bearer <token>` header. Station is derived from
# hostname (orc-<station> → <station>).
#
# Watermark semantics (per-file, resumable):
#   - Files are uploaded oldest-mtime-first; after each success STATE_FILE's
#     mtime is advanced to that file's mtime (touch -r). Progress therefore
#     persists even if the wake cycle is cut short mid-batch — the next run
#     resumes where this one stopped instead of re-sending the whole backlog.
#   - Oldest-first is by mtime, not filename, so sensors interleave fairly
#     and none is systematically last (which previously starved sht40).
#   - PUTs are idempotent (same URL = same effect), so a file re-sent after
#     an interruption is harmless.
#
# Boot-race handling:
#   - This runs a few seconds after boot, before the LTE modem has
#     registered, so the first PUTs can hit DNS/connect failures (curl 6/7).
#     curl --retry* rides out the modem warm-up instead of aborting the batch.
#
# Each PUT is bounded by --max-time MAX_PER_FILE_SECS so a stalled upload
# fails fast rather than getting killed by the wake-cycle shutdown.

set -euo pipefail

TAG="orc-sensors-upload"
# CONF and STATION are env-overridable for local testing. In production both
# come from their defaults (config in /etc/orc/, station from hostname).
CONF="${ORC_SENSORS_UPLOAD_CONF:-/etc/orc/sensors-upload.conf}"

log() { logger -t "$TAG" -- "$1"; echo "[$TAG] $1"; }

if [ ! -f "$CONF" ]; then
    log "config $CONF missing — nothing to do"
    exit 0
fi
# shellcheck source=/dev/null
. "$CONF"

if [ "${ENABLED:-0}" != "1" ]; then
    log "disabled (ENABLED != 1) — skipping"
    exit 0
fi

# Pull UPLOAD_TOKEN from ~pi/.orc_deploy_<site> if not already in env.
# Same pattern orc-capture uses for CAMERA_PASS.
if [ -z "${UPLOAD_TOKEN:-}" ]; then
    for f in /home/pi/.orc_deploy_*; do
        if [ -f "$f" ]; then
            # shellcheck source=/dev/null
            . "$f"
        fi
    done
fi

for v in UPLOAD_URL LOG_DIR STATE_FILE UPLOAD_TOKEN; do
    if [ -z "${!v:-}" ]; then
        log "ERROR: $v not set (check $CONF and ~pi/.orc_deploy_<site>)"
        exit 1
    fi
done

# CACERT is required for TLS pinning. The server uses a self-signed cert;
# without a pinned CA, curl will refuse to connect. An empty CACERT means
# the script is misconfigured (don't fall back to --insecure — that would
# defeat the point of pinning).
if [ -z "${CACERT:-}" ]; then
    log "ERROR: CACERT not set in $CONF (no pinned CA — refusing to upload)"
    exit 1
fi
if [ ! -r "$CACERT" ]; then
    log "ERROR: CACERT $CACERT not readable"
    exit 1
fi

if [ ! -d "$LOG_DIR" ]; then
    log "LOG_DIR $LOG_DIR missing — nothing to do"
    exit 0
fi

STATION="${STATION:-$(hostname | sed 's/^orc-//')}"
if [ -z "$STATION" ]; then
    log "ERROR: could not derive station (set STATION env var or run on a host named orc-<station>)"
    exit 1
fi

# Normalize endpoint (no trailing slash so we don't double up)
UPLOAD_URL="${UPLOAD_URL%/}"

# Make sure STATE_FILE parent exists (on first run it may not)
mkdir -p "$(dirname "$STATE_FILE")"

# Select files modified since the last successful upload, ordered
# oldest-mtime-first (see "Watermark semantics" above). The %T@ prefix is
# the sort key and is stripped back off before use.
find_args=()
if [ -f "$STATE_FILE" ]; then
    find_args=(-newer "$STATE_FILE")
fi
mapfile -d '' files < <(
    find "$LOG_DIR" -type f "${find_args[@]}" -printf '%T@\t%p\0' \
        | sort -z -n | cut -z -f2-
)

if [ "${#files[@]}" -eq 0 ]; then
    log "no new files since last upload — nothing to do"
    exit 0
fi

MAX_PER_FILE_SECS="${MAX_PER_FILE_SECS:-20}"
CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"
RETRY_COUNT="${RETRY_COUNT:-5}"
RETRY_DELAY="${RETRY_DELAY:-2}"

log "uploading ${#files[@]} file(s) to ${UPLOAD_URL}/${STATION}/"
ok=0
for f in "${files[@]}"; do
    fname=$(basename "$f")
    target="${UPLOAD_URL}/${STATION}/${fname}"
    # --ipv4 forces curl to use the IPv4 path. Required because Indonesian
    # carriers (Telkomsel etc.) use NAT64, and the resulting IPv6 path has
    # a PMTU black hole that breaks TLS handshakes when the server cert is
    # large (our 4096-bit RSA cert overflows the post-NAT64 MTU). TCP
    # connects fine over IPv6; the Server Hello+Certificate response
    # fragments and is silently dropped. IPv4 path avoids the fragmentation
    # issue entirely. If we ever switch to a smaller cert (RSA 2048 or
    # ECDSA), this flag becomes optional.
    #
    # --retry* absorbs the post-boot LTE warm-up: the first PUTs of a cycle
    # often fail with curl 6 (DNS) / 7 (connect) before the modem registers.
    # Retrying rides that out; on a healthy link PUTs succeed first try and
    # these flags cost nothing.
    if curl -sS -X PUT \
        --ipv4 \
        --retry "$RETRY_COUNT" \
        --retry-delay "$RETRY_DELAY" \
        --retry-connrefused \
        --retry-all-errors \
        --data-binary "@${f}" \
        -H "Authorization: Bearer ${UPLOAD_TOKEN}" \
        -H "Content-Type: text/csv" \
        -H "Connection: close" \
        --cacert "$CACERT" \
        --connect-timeout "$CONNECT_TIMEOUT" \
        --max-time "$MAX_PER_FILE_SECS" \
        --fail \
        --output /dev/null \
        "$target"; then
        ok=$((ok+1))
        # Persist progress: advance the watermark to this file's mtime.
        # Uploads are oldest-mtime-first, so this only ever moves forward.
        touch -r "$f" "$STATE_FILE"
    else
        rc=$?
        log "ERROR: PUT failed (curl exit $rc) for $f -> $target after $ok successful upload(s); watermark held at last success"
        exit 1
    fi
done

log "uploaded $ok file(s); watermark advanced"
