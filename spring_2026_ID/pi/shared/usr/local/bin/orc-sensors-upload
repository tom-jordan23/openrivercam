#!/bin/bash
# orc-sensors-upload — push new sensor CSVs to the LiveORC server via HTTPS PUT
#
# SEPARATION OF CONCERNS NOTE: This script is invoked from orc-capture as a
# step in the wake-cycle, not because sensor upload belongs in capture but
# because we need wake-cycle sequencing to avoid being killed by ORC-OS's
# shutdown trigger. The long-term plan is to extract capture, sensor upload,
# and shutdown decision into an orc-cycle orchestrator. Don't expand this
# script's responsibilities; if you need additional pre-upload work, add a
# separate step in orc-capture rather than bundling here.
#
# Reads /etc/orc/sensors-upload.conf for UPLOAD_URL / LOG_DIR / STATE_FILE.
# Reads ~pi/.orc_deploy_<site> for UPLOAD_TOKEN (out-of-band secret).
# Files under LOG_DIR newer than STATE_FILE's mtime are PUT to:
#   <UPLOAD_URL>/<station>/<filename>
# with an `Authorization: Bearer <token>` header. Station is derived from
# hostname (orc-<station> → <station>).
#
# Watermark semantics:
#   - A temp file is touched before scanning, capturing "now".
#   - If all PUTs succeed, the temp file replaces STATE_FILE atomically.
#   - If any PUT fails, the old watermark stays, and the next run retries
#     the whole batch. PUTs are idempotent (same URL = same effect), so
#     re-uploading a few files is cheap.
#
# Each PUT is bounded by --max-time MAX_PER_FILE_SECS so a stalled upload
# fails fast rather than getting killed by the wake-cycle shutdown.

set -euo pipefail

TAG="orc-sensors-upload"
# CONF and STATION are env-overridable for local testing. In production both
# come from their defaults (config in /etc/orc/, station from hostname).
CONF="${ORC_SENSORS_UPLOAD_CONF:-/etc/orc/sensors-upload.conf}"

log() { logger -t "$TAG" -- "$1"; echo "[$TAG] $1"; }

if [ ! -f "$CONF" ]; then
    log "config $CONF missing — nothing to do"
    exit 0
fi
# shellcheck source=/dev/null
. "$CONF"

if [ "${ENABLED:-0}" != "1" ]; then
    log "disabled (ENABLED != 1) — skipping"
    exit 0
fi

# Pull UPLOAD_TOKEN from ~pi/.orc_deploy_<site> if not already in env.
# Same pattern orc-capture uses for CAMERA_PASS.
if [ -z "${UPLOAD_TOKEN:-}" ]; then
    for f in /home/pi/.orc_deploy_*; do
        if [ -f "$f" ]; then
            # shellcheck source=/dev/null
            . "$f"
        fi
    done
fi

for v in UPLOAD_URL LOG_DIR STATE_FILE UPLOAD_TOKEN; do
    if [ -z "${!v:-}" ]; then
        log "ERROR: $v not set (check $CONF and ~pi/.orc_deploy_<site>)"
        exit 1
    fi
done

if [ ! -d "$LOG_DIR" ]; then
    log "LOG_DIR $LOG_DIR missing — nothing to do"
    exit 0
fi

STATION="${STATION:-$(hostname | sed 's/^orc-//')}"
if [ -z "$STATION" ]; then
    log "ERROR: could not derive station (set STATION env var or run on a host named orc-<station>)"
    exit 1
fi

# Normalize endpoint (no trailing slash so we don't double up)
UPLOAD_URL="${UPLOAD_URL%/}"

# Make sure STATE_FILE parent exists (on first run it may not)
mkdir -p "$(dirname "$STATE_FILE")"

# Capture "now" before scanning — anything modified after this point
# will be caught on the next run.
NEW_WATERMARK="$(mktemp)"
trap 'rm -f "$NEW_WATERMARK"' EXIT

find_args=()
if [ -f "$STATE_FILE" ]; then
    find_args=(-newer "$STATE_FILE")
fi

# Read NUL-delimited file list into an array, sorted oldest-first.
mapfile -d '' files < <(find "$LOG_DIR" -type f "${find_args[@]}" -print0 | sort -z)

if [ "${#files[@]}" -eq 0 ]; then
    log "no new files since last upload — advancing watermark"
    mv "$NEW_WATERMARK" "$STATE_FILE"
    trap - EXIT
    exit 0
fi

MAX_PER_FILE_SECS="${MAX_PER_FILE_SECS:-20}"
CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"

log "uploading ${#files[@]} file(s) to ${UPLOAD_URL}/${STATION}/"
ok=0
for f in "${files[@]}"; do
    fname=$(basename "$f")
    target="${UPLOAD_URL}/${STATION}/${fname}"
    if curl -sS -X PUT \
        --data-binary "@${f}" \
        -H "Authorization: Bearer ${UPLOAD_TOKEN}" \
        -H "Content-Type: text/csv" \
        -H "Connection: close" \
        --connect-timeout "$CONNECT_TIMEOUT" \
        --max-time "$MAX_PER_FILE_SECS" \
        --fail \
        --output /dev/null \
        "$target"; then
        ok=$((ok+1))
    else
        rc=$?
        log "ERROR: PUT failed (curl exit $rc) for $f -> $target after $ok successful upload(s); watermark not advanced"
        exit 1
    fi
done

mv "$NEW_WATERMARK" "$STATE_FILE"
trap - EXIT
log "uploaded $ok file(s); watermark advanced"
