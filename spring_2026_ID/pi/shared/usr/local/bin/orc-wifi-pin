#!/usr/bin/env bash
#
# orc-wifi-pin — pin wlan0 to the currently-connected SSID
#
# Captures the SSID wlan0 is currently associated with, deletes every
# other NetworkManager wifi profile, and configures the kept profile to
# autoconnect at boot and reconnect indefinitely whenever the AP appears.
#
# Intended for field stations that live behind a dedicated MiFi: once
# connected, we don't want the Pi wandering to any other saved SSID.
#
# Usage:
#   orc-wifi-pin                 # interactive, prompts before deleting
#   orc-wifi-pin --yes           # apply without prompting
#   orc-wifi-pin --dry-run       # show plan, change nothing
#   orc-wifi-pin -h|--help       # this help
#
# Safety:
#   - Refuses to run if wlan0 is not currently associated.
#   - Only touches 802-11-wireless profiles; ethernet/VPN profiles
#     (camera-net, tailscale0, etc.) are left alone.

set -euo pipefail

YES=0
DRY_RUN=0

while [ $# -gt 0 ]; do
    case "$1" in
        --yes|-y)     YES=1 ;;
        --dry-run|-n) DRY_RUN=1 ;;
        -h|--help)    sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
        *) echo "Unknown option: $1" >&2; exit 2 ;;
    esac
    shift
done

if ! command -v nmcli >/dev/null 2>&1; then
    echo "ERROR: nmcli not found — NetworkManager required." >&2
    exit 1
fi

# ─── Detect the active wifi connection on wlan0 ──────────────────────
# Use -g for a single field so we don't have to parse nmcli's ':'-escaped
# terse output. Empty string means wlan0 isn't associated.
active_name=$(nmcli -t -g GENERAL.CONNECTION device show wlan0 2>/dev/null | head -1)

if [ -z "$active_name" ]; then
    echo "ERROR: no active wifi connection on wlan0 — nothing to pin." >&2
    echo "       Connect to the target SSID first, then re-run." >&2
    exit 1
fi

active_ssid=$(nmcli -t -s -g 802-11-wireless.ssid con show "$active_name" 2>/dev/null || echo "")

echo "Active wifi: '$active_name' (SSID: ${active_ssid:-<unknown>})"
echo

# ─── Gather other wifi profiles ──────────────────────────────────────
# Put TYPE first so we can strip it with a single sub() regardless of
# any ':' characters escaped inside NAME.
mapfile -t all_wifi < <(nmcli -t -f TYPE,NAME con show 2>/dev/null \
    | awk -F: '$1=="802-11-wireless"{sub(/^[^:]*:/,""); print}')

to_delete=()
for name in "${all_wifi[@]}"; do
    [ "$name" = "$active_name" ] && continue
    to_delete+=("$name")
done

if [ ${#to_delete[@]} -eq 0 ]; then
    echo "No other wifi profiles to remove."
else
    echo "Will DELETE ${#to_delete[@]} other wifi profile(s):"
    for n in "${to_delete[@]}"; do echo "  - $n"; done
fi

echo
echo "Will configure '$active_name' with:"
echo "  connection.autoconnect          = yes"
echo "  connection.autoconnect-priority = 100"
echo "  connection.autoconnect-retries  = 0   (infinite)"

if [ "$DRY_RUN" -eq 1 ]; then
    echo
    echo "--dry-run: no changes made."
    exit 0
fi

if [ "$YES" -ne 1 ]; then
    echo
    read -r -p "Apply these changes? [y/N] " reply
    case "$reply" in
        y|Y|yes|YES) ;;
        *) echo "Aborted."; exit 1 ;;
    esac
fi

# ─── Apply ───────────────────────────────────────────────────────────
for n in "${to_delete[@]}"; do
    echo "Deleting: $n"
    sudo nmcli con delete "$n"
done

echo "Configuring: $active_name"
sudo nmcli con modify "$active_name" \
    connection.autoconnect yes \
    connection.autoconnect-priority 100 \
    connection.autoconnect-retries 0

echo
echo "Done. wlan0 is pinned to '$active_name'."
