# Copy to .env on the server and fill in real tokens. Never commit .env.
#
# Generate each token with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
#
# Format: comma-separated <station>:<token> pairs, no spaces around commas.
# Station names must match Pi hostnames (orc-<station>) with the orc- prefix
# stripped.

ORC_UPLOAD_TOKENS=sukabumi:REPLACE_ME,jakarta:REPLACE_ME
