# Copy to .env on the server and fill in real values. Never commit .env.
#
# Generate each token / password with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# (the password manager is the source of truth — paste from there, don't
# regenerate ad-hoc when adding stations or rebuilding the host)

# --- sensor-upload -----------------------------------------------------
# Comma-separated <station>:<token> pairs, no spaces.
# Station names match Pi hostnames (orc-<station>) with the orc- prefix
# stripped.
ORC_UPLOAD_TOKENS=sukabumi:REPLACE_ME,jakarta:REPLACE_ME

# --- timescale ---------------------------------------------------------
# Postgres password for the orc-grafana / orc-sensor-ingest containers.
TIMESCALE_PASSWORD=REPLACE_ME

# --- grafana -----------------------------------------------------------
# Admin password for the orc-grafana web UI (login user is orc-admin).
# Anonymous viewers do NOT need this; it's only for dashboard editing.
GRAFANA_ADMIN_PASSWORD=REPLACE_ME
