# Pi config files with real credentials (use placeholders in tracked files)
spring_2026_ID/pi/**/*.local

# Camera config credentials and local overrides
spring_2026_ID/camera/.env
spring_2026_ID/camera/**/*.local

# LiveORC server-side .env (contains ORC_UPLOAD_TOKENS)
spring_2026_ID/liveorc_server/.env

# Python venv for doc tools (translation)
spring_2026_ID/docs/.venv/

# Python venvs anywhere in the repo (created for pyorc etc.)
.venv/
venv/
__pycache__/
*.pyc

# Build photos (large, not version controlled)
spring_2026_ID/build_photos/

# Survey exports (real GPS coordinates of deployment sites)
spring_2026_ID/survey_data/

# Bringup runtime data: input files (calibration JSON / geojson with real
# coords) + state / session logs / .env. Scripts and the data/state README
# placeholders themselves are tracked. NOTE: must explicitly re-include the
# bringup data/ dir because the top-of-file 'data/' rule shadows it.
!spring_2026_ID/sukabumi_bringup/data/
spring_2026_ID/sukabumi_bringup/data/*
!spring_2026_ID/sukabumi_bringup/data/README.md
spring_2026_ID/sukabumi_bringup/state/*
!spring_2026_ID/sukabumi_bringup/state/.gitkeep
spring_2026_ID/sukabumi_bringup/.env
spring_2026_ID/sukabumi_bringup/*.log

# Video files (large binaries)
*.mp4

# PDFs are tracked in git for easy access by non-technical users.
# Rebuild with: cd spring_2026_ID/docs && ./build_pdf.sh

# macOS Finder metadata
.DS_Store

# Sukabumi handoff folder (real GPS coords, .env with camera password)
spring_2026_ID/sukabumi_handoff/
